rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Main user backups and sync state
    match /user_backups/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create, update: if isOwner(userId) && isValidId(userId)
        && request.resource.data.userId == userId
        && request.resource.data.updatedAt is number;
      allow delete: if isOwner(userId) && isValidId(userId);

      // Subcollection of individual image items
      match /images/{imageId} {
        allow get, list: if isOwner(userId) && isValidId(userId) && isValidId(imageId);
        allow create, update: if isOwner(userId) && isValidId(userId) && isValidId(imageId)
          && request.resource.data.id == imageId
          && request.resource.data.title is string
          && request.resource.data.title.size() <= 200
          && request.resource.data.url is string
          && request.resource.data.url.size() <= 1048576
          && request.resource.data.quantity is number
          && request.resource.data.quantity >= 0
          && request.resource.data.createdAt is number
          && request.resource.data.updatedAt is number;
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(imageId);
      }
    }
  }
}
